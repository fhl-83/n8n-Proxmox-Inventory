    {
      "parameters": {
        "jsCode": "// Code node \"Dedup VMs\"\n// Mode: Run Once for All Items\n\nconst seen = new Set();\nconst out = [];\n\nfor (const item of items) {\n  const j = item.json || {};\n\n  // On fabrique une clé unique par VM\n  const node = j.node || j.nodename || '';\n  const vmid = j.vmid != null ? String(j.vmid) : '';\n  const hostname = j.hostname || j.name || '';\n\n  const key = `${node}|${vmid}|${hostname}`;\n\n  if (seen.has(key)) {\n    // VM déjà vue -> on la zappe\n    continue;\n  }\n\n  seen.add(key);\n  out.push(item);\n}\n\nreturn out;\n"
      },
