    {
      "parameters": {
        "jsCode": "// Node: QEMU → Markdown (simple)\n// Mode: Run Once for All Items\n\n// On récupère toutes les VMs\nconst vms = items.map(i => i.json);\n\n// Optionnel : trier par node puis VMID si tu veux un ordre stable\nvms.sort((a, b) => {\n  if ((a.node || \"\") < (b.node || \"\")) return -1;\n  if ((a.node || \"\") > (b.node || \"\")) return 1;\n  return (a.vmid || 0) - (b.vmid || 0);\n});\n\n// Fonction pour formater les interfaces d'une VM\nfunction formatInterfaces(vm) {\n  if (!vm.interfaces || vm.interfaces.length === 0) {\n    return \"\";\n  }\n\n  // Tri des interfaces dans l'ordre net0, net1, net2,...\n  const list = [...vm.interfaces].sort((a, b) =>\n    (a.name || \"\").localeCompare(b.name || \"\", undefined, { numeric: true })\n  );\n\n  return list\n    .map(intf => {\n      const ip = intf.ip || \"\";\n      const bridge = intf.bridge ? ` [${intf.bridge}]` : \"\";\n      return `${intf.name}: ${ip}${bridge}`;\n    })\n    .join(\"<br>\");\n}\n\n// Construction du markdown\nlet md = `# Inventaire IP — VMs QEMU\\n\\n_MAJ: ${new Date().toISOString()}_\\n\\n`;\n\nmd += `| VMID | Hostname | Interfaces |\\n`;\nmd += `|-----:|----------|:-----------|\\n`;\n\nfor (const vm of vms) {\n  const vmid = vm.vmid ?? \"—\";\n  const hostname = vm.hostname ?? vm.name ?? \"—\";\n  const interfaces = formatInterfaces(vm);\n\n  md += `| ${vmid} | ${hostname} | ${interfaces} |\\n`;\n}\n\nmd += `\\n<!-- KNOWN_IPS:[] -->\\n`;\n\nreturn [\n  {\n    json: {\n      markdown: md,\n    },\n  },\n];\n"
      },
