    {
      "parameters": {
        "jsCode": "// Code node\n// Mode: Run Once for All Items\n\n// Récupère tous les items de Merge QEMU Nodes (node/vmid/name)\nconst merge2Items = $items('Merge QEMU Nodes', 0); // runIndex 0\n// Récupère tous les items de Merge QEMU Config And Network (GA network-get-interfaces)\nconst merge1Items = $items('Merge QEMU Config And Network', 0); // runIndex 0\n\nconst out = [];\n\n// petite fonction utilitaire pour filtrer les IPv4 valides\nfunction isValidIPv4(ip) {\n  if (!ip) return false;\n  if (ip === '127.0.0.1') return false;          // loopback\n  if (ip.startsWith('169.254.')) return false;   // APIPA\n  return true;\n}\n\nfor (let i = 0; i < merge2Items.length; i++) {\n  const ctx = merge2Items[i]?.json || {};\n  const ga  = merge1Items[i]?.json || {};\n\n  const node = ctx.node || null;\n  const vmid = ctx.vmid || null;\n  const hostname = ctx.name || null;\n\n  const result = (ga.data && ga.data.result) || [];\n  const interfaces = [];\n\n  for (const iface of result) {\n    const ifName = iface.name || '';\n    const macRaw = iface['hardware-address'] || '';\n    const mac = macRaw.toLowerCase();\n\n    // skip MAC nulles\n    if (!mac || mac === '00:00:00:00:00:00') continue;\n\n    const ipAddrs = iface['ip-addresses'] || [];\n    const ipv4s = ipAddrs\n      .filter(ip => ip['ip-address-type'] === 'ipv4')\n      .map(ip => ip['ip-address'])\n      .filter(isValidIPv4);\n\n    for (const ip of ipv4s) {\n      interfaces.push({\n        name: ifName,\n        mac,\n        ip,\n      });\n    }\n  }\n\n  out.push({\n    json: {\n      node,\n      vmid,\n      hostname,\n      interfaces,\n    },\n  });\n}\n\nreturn out;\n"
      },
